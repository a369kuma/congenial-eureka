   "source": [
    "def calculate_gcd(n, m):\n",
    "    \n",
    "    if m == 0:\n",
    "        return n\n",
    "\n",
    "    return calculate_gcd(m, n % m)\n",
    "\n",
    "# test\n",
    "num1 = 48\n",
    "num2 = 18\n",
    "result = calculate_gcd(num1, num2)\n",
    "\n",
    "print(f\"The GCD of {num1} and {num2} is: {result}\")"
   ]
  }
